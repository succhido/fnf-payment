# Copy this file to ".env" (same folder) and fill in the two values.
# .env is gitignored — it never leaves this machine.

# From https://developer.abnamro.com (your app's API key for the Tikkie product)
TIKKIE_API_KEY=paste-api-key-here

# From the Tikkie Business Portal -> Settings -> API -> create app
TIKKIE_APP_TOKEN=paste-app-token-here

# Uncomment to test against the sandbox first (recommended dry run):
# TIKKIE_SANDBOX=1
